{
  "name": "black-gold",
  "version": "1.0.0",
  "description": "Brent crude geopolitical signal analyzer + Trading 212 executor",
  "main": "src/brent/index.ts",
  "type": "module",
  "scripts": {
    "start":      "tsx src/brent/index.ts",
    "brent":      "tsx src/brent/index.ts",
    "btc":        "tsx src/bitcoin/index.ts",
    "execute":    "tsx src/brent/index.ts --execute --quantity 1 --auto-confirm",
    "btc:execute":"tsx src/bitcoin/index.ts --execute --quantity 1 --auto-confirm",
    "search":     "tsx src/brent/index.ts --search-instruments brent",
    "build":      "tsc",
    "typecheck":  "tsc --noEmit",
    "test":       "vitest run",
    "test:watch": "vitest",
    "coverage":   "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "rss-parser": "^3.13.0",
    "yahoo-finance2": "^2.13.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
